                 |Content-Type: application/http| && lv_cr_lf &&
                 |Content-Transfer-Encoding: binary| && lv_cr_lf &&
                 |Content-ID: 1| && lv_cr_lf &&
                 lv_cr_lf &&

                 |PATCH PurchaseReqnItem(PurchaseRequisition='{ iv_pr }',PurchaseRequisitionItem='{ iv_pr_item }') HTTP/1.1| && lv_cr_lf &&
                 |Content-Type: application/json| && lv_cr_lf &&
                 |If-Match: *| && lv_cr_lf &&
                 lv_cr_lf &&

                 |\{ "AccountAssignmentCategory" : "A", "MultipleAcctAssgmtDistribution" : "{ lv_distribution }" \}| && lv_cr_lf &&
                 lv_cr_lf.

    " 4. LOOP for Account Assignments (Dynamic Part)
    " We start from 1 up to your variable 'lv_count'
    DATA(lv_count) = iv_assignments .
    DATA(lv_count_create) = lines( iv_asset ) - iv_assignments.
    DO lv_count TIMES.
      DATA(lv_index) = sy-index.
      " Format index to 2 digits (e.g., 01, 02) for the OData key
      " DATA(lv_index_str) = |{ lv_index WIDTH = 2 ALIGN = RIGHT PAD = '0' }|.

      " Each assignment needs a unique Content-ID (starting after the first PATCH, so index + 1)
      DATA(lv_content_id) = lv_index + 1.
      " data(lv_a_num) = |{ lv_index ALPHA = IN }|.
      lv_payload = lv_payload &&

                   lv_cr_lf &&
                   |--changeset| && lv_cr_lf &&
                   |Content-Type: application/http| && lv_cr_lf &&
                   |Content-Transfer-Encoding: binary| && lv_cr_lf &&
                   |Content-ID: { lv_content_id }| && lv_cr_lf &&
                   lv_cr_lf &&

                   |PATCH PurchaseReqnAcctAssgmt(PurchaseRequisition='{ iv_pr }',PurchaseRequisitionItem='{ iv_pr_item }',PurchaseReqnAcctAssgmtNumber='{ lv_index }') HTTP/1.1| && lv_cr_lf &&
                   |Content-Type: application/json| && lv_cr_lf &&
                   |If-Match: *| && lv_cr_lf &&
                   lv_cr_lf &&

                   |\{ | &&
                   |"MasterFixedAsset" : "{ iv_asset[ lv_index ]-asset }", | &&
                   |"CostCenter" : "{ iv_asset[ lv_index ]-cc }", | &&
                   |"BaseUnitISOCode" : "{ iv_isocode }", | &&
                   |"Quantity" : 1 | &&
                   |\}| && lv_cr_lf &&
                   lv_cr_lf.
    ENDDO.
    DATA(lv_assign_num) = iv_assignments.
    DO lv_count_create TIMES.
      lv_assign_num = lv_assign_num + 1.
      lv_content_id = lv_content_id + 1.
      " data(lv_a_num1) = |{ lv_assign_num ALPHA = IN }|.
      lv_payload = lv_payload &&

                   lv_cr_lf &&
                   |--changeset| && lv_cr_lf &&
                   |Content-Type: application/http| && lv_cr_lf &&
                   |Content-Transfer-Encoding: binary| && lv_cr_lf &&
                   |Content-ID: { lv_content_id }| && lv_cr_lf &&
                   lv_cr_lf &&

                   |POST PurchaseReqnAcctAssgmt HTTP/1.1| && lv_cr_lf &&
                   |Content-Type: application/json| && lv_cr_lf &&
                   |If-Match: *| && lv_cr_lf &&
                   lv_cr_lf &&

                   |\{ | &&
                   |"PurchaseRequisition" : "{ iv_pr }", | &&
                   |"PurchaseRequisitionItem" : "{ iv_pr_item }", | &&
                   |"PurchaseReqnAcctAssgmtNumber" : "{ lv_assign_num }", | &&
                   |"MasterFixedAsset" : "{ iv_asset[ lv_assign_num ]-asset }", | &&
                   |"CostCenter" : "{ iv_asset[ lv_assign_num ]-cc }", | &&
                   |"BaseUnitISOCode" : "{ iv_isocode }", | &&
                   |"Quantity" : 1 | &&
                   |\}| && lv_cr_lf &&
                   lv_cr_lf.

    ENDDO.

    " 5. Close Changeset and Close Batch
    lv_payload = lv_payload &&

                 |--changeset--| && lv_cr_lf &&
                 lv_cr_lf &&
                 |--batch--|.


    "DATA(lv_payload) = '{ "AccountAssignmentCategory": "' && iv_aa_cat && '", "MasterFixedAsset" : "' && iv_asset && '" }'.
