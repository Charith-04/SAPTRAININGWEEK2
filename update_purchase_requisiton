    DATA(lv_body) = lo_http->response->get_cdata(  ).

    DATA lv_pos1 TYPE i.
    DATA lv_pos2 TYPE i.

" Find sap-messages block
FIND 'sap-messages:' IN lv_body MATCH OFFSET lv_pos1.
