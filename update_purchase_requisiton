    " 1. Start of Batch and the initial GET request
    DATA(lv_payload) = |--batch| && lv_cr_lf &&

                 |Content-Type: application/http| && lv_cr_lf &&
                 |Content-Transfer-Encoding: binary| && lv_cr_lf &&
                 lv_cr_lf &&

                 |GET PurchaseReqnItem(PurchaseRequisition='{ iv_pr }',PurchaseRequisitionItem='{ iv_pr_item }') HTTP/1.1| && lv_cr_lf &&
